# Winti Guide – Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://dphhqwisluirihmahyee.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe – App-Nutzer Premium (B2C) ────────────────────────────────────────
# Erstelle Payment Links in Stripe Dashboard → Payment Links
# Füge ?client_reference_id={supabase_user_id} an die URL an (optional, für Webhook-Matching)
EXPO_PUBLIC_STRIPE_PREMIUM_MONTHLY_URL=https://buy.stripe.com/your-monthly-link
EXPO_PUBLIC_STRIPE_PREMIUM_YEARLY_URL=https://buy.stripe.com/your-yearly-link

# ── Stripe – Partner-Abos (B2B) ──────────────────────────────────────────────
# Separate Payment Links für die drei Partner-Pakete
EXPO_PUBLIC_STRIPE_PARTNER_STARTER_URL=https://buy.stripe.com/your-starter-link
EXPO_PUBLIC_STRIPE_PARTNER_PRO_URL=https://buy.stripe.com/your-pro-link
EXPO_PUBLIC_STRIPE_PARTNER_PREMIUM_URL=https://buy.stripe.com/your-premium-link

# ── Supabase Edge Function Secrets (via supabase secrets set) ─────────────────
# Diese Werte werden NICHT in der App verwendet – nur in der Edge Function.
# Setze sie mit: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
